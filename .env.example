# ─────────────────────────────────────────────────────────────────────────────
# Link Shortener — environment variables (ARCHITECTURE.md §10.5)
# Copy to `.env` for local dev. No real secrets are committed here.
# Email/password auth works fully offline; OAuth needs free dev client IDs.
# ─────────────────────────────────────────────────────────────────────────────

# --- Datastores -------------------------------------------------------------
# When running the app on the host with `pnpm db:up`, use localhost.
# Inside docker-compose, the web/worker services override these to the service
# hostnames (postgres / redis) via compose `environment:`.
DATABASE_URL="postgresql://shortener:shortener@localhost:5432/shortener?schema=public"
REDIS_URL="redis://localhost:6379/0"

# --- Auth.js (NextAuth v5) --------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="dev-only-insecure-secret-change-me-please-32b"
NEXTAUTH_URL="http://localhost:3000"

# OAuth providers (optional locally — leave blank to hide those buttons).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Public URL / short domain ---------------------------------------------
# shortUrl is built from BASE_URL. Same origin serves app + short links (OQ-B).
BASE_URL="http://localhost:3000"

# --- Privacy / hashing ------------------------------------------------------
# Server pepper for HMAC visitor-key hashing (A-PII). MUST be set in prod.
VISITOR_IP_PEPPER="dev-only-pepper-change-me"

# --- GeoIP (optional; degrades gracefully if absent) ------------------------
# Free MaxMind license key to auto-download GeoLite2-City via `pnpm fetch:geoip`.
# Or drop the file manually at data/GeoLite2-City.mmdb (git-ignored). See §10.3.
MAXMIND_LICENSE_KEY=""
GEOIP_DB_PATH="data/GeoLite2-City.mmdb"

# --- Rate limiting (token bucket) ------------------------------------------
# Shorten: capacity tokens, refilled at rate per window seconds.
RL_SHORTEN_CAPACITY="20"
RL_SHORTEN_REFILL="20"
RL_SHORTEN_WINDOW_SEC="60"
# Password unlock: stricter, independent limiter with lockout (FR-18).
RL_UNLOCK_CAPACITY="5"
RL_UNLOCK_REFILL="5"
RL_UNLOCK_WINDOW_SEC="300"
RL_UNLOCK_LOCKOUT_SEC="900"

# --- Redirect / cache / lifecycle ------------------------------------------
REDIRECT_STATUS="302"
REDIRECT_CACHE_TTL="3600"          # seconds; resolved-redirect cache TTL
REDIRECT_NEGATIVE_CACHE_TTL="60"   # seconds; not-found / dead negative cache
CLICK_RETENTION_DAYS="400"
GUEST_TTL_HOURS="24"
BULK_MAX="100"
UNLOCK_SESSION_TTL_SEC="1800"      # short-lived unlock cookie/session (FR-17)

# --- Click ingestion stream -------------------------------------------------
CLICK_STREAM_MAXLEN="100000"       # capped stream length (XADD MAXLEN ~)
