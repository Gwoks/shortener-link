# Link Shortener — environment (Rust/Axum + SQLite). Copy to `.env`.
# Defaults below run the whole app locally with no external services.

# ── Core ───────────────────────────────────────────────────────────────────
# Public URL the app is served at (used to build short URLs + OAuth callbacks).
BASE_URL=http://localhost:8080
# Port the single Rust binary listens on (serves API + redirect + static SPA).
PUBLIC_PORT=8080
# Path to the SQLite database file (created on first run; WAL mode).
SQLITE_PATH=data/app.db
# Directory holding the built Vite frontend (output of `pnpm build`).
STATIC_DIR=dist
# Secret used to sign/verify the session JWT cookie. CHANGE IN PRODUCTION (>=32 bytes).
AUTH_SECRET=dev-only-insecure-secret-change-me-please-32b

# ── OAuth (optional; leave blank to disable a provider) ──────────────────────
# Redirect URI to register: ${BASE_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI to register: ${BASE_URL}/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Analytics / abuse ────────────────────────────────────────────────────────
# Pepper for hashing visitor identifiers (unique-visitor counting). CHANGE IT.
VISITOR_IP_PEPPER=dev-only-pepper-change-me
# Optional MaxMind GeoLite2 City DB for geo analytics (geo degrades to none if absent).
GEOIP_DB_PATH=data/GeoLite2-City.mmdb
MAXMIND_LICENSE_KEY=

# ── Redirect / lifecycle ─────────────────────────────────────────────────────
REDIRECT_STATUS=302
REDIRECT_CACHE_TTL=3600
REDIRECT_NEGATIVE_CACHE_TTL=60
CLICK_RETENTION_DAYS=400
GUEST_TTL_HOURS=24
BULK_MAX=100
UNLOCK_SESSION_TTL_SEC=1800

# ── Rate limiting ────────────────────────────────────────────────────────────
RL_SHORTEN_CAPACITY=20
RL_SHORTEN_REFILL=20
RL_SHORTEN_WINDOW_SEC=60
RL_UNLOCK_CAPACITY=5
RL_UNLOCK_REFILL=5
RL_UNLOCK_WINDOW_SEC=300
RL_UNLOCK_LOCKOUT_SEC=900
