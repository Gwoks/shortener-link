# Test environment — uses a SEPARATE database and Redis DB index so tests
# never clobber dev data (ARCHITECTURE.md §10.4). Integration tests that need
# infra read these; pure unit tests need none of it.
DATABASE_URL="postgresql://shortener:shortener@localhost:5432/shortener_test?schema=public"
REDIS_URL="redis://localhost:6379/1"
NEXTAUTH_SECRET="test-only-secret-aaaaaaaaaaaaaaaaaaaaaaaaaaaa"
NEXTAUTH_URL="http://localhost:3000"
BASE_URL="http://localhost:3000"
VISITOR_IP_PEPPER="test-pepper"
REDIRECT_STATUS="302"
REDIRECT_CACHE_TTL="3600"
GUEST_TTL_HOURS="24"
BULK_MAX="100"
